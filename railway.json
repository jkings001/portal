{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd showcase && pnpm install && pnpm build"
  },
  "deploy": {
    "startCommand": "cd showcase && pnpm start",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowSeconds": 600
  }
}
